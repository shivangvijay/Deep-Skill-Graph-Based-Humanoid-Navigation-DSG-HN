<!-- G1 29-DOF scene: robot + floor, obstacles, stairs, terrain heightfields -->
<mujoco model="g1_29dof scene">
  <include file="g1_29dof.xml"/>

  <!-- NOTE: SEEMS TO WORK BETTER IF WE SIMULATE AT A FASTER FREQUENCY. SHOULD DISCUSS THIS AND OTHER CONTROL FREQUENCIES -->
  <!-- <option timestep="0.001" iterations="50" solver="Newton" integrator="implicitfast"/> -->
  <statistic center="0 0 0.5" extent="2.0"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <!-- Floor -->
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
    <!-- Real-world layout: three boxes; origin (0,30,0) cm = new (0,0,0), x unchanged. Sizes unchanged. -->
    <!-- Box 1: 255×142×105 cm. Center in new origin: (127.5,-101,52.5) cm -->
    <geom name="layout_box1" type="box" pos="1.275 -1.01 0.525" size="1.275 0.71 0.525" quat="1 0 0 0"/>
    <!-- Box 2: 85×120×100 cm. Center in new origin: (-202.5,60,50) cm -->
    <geom name="layout_box2" type="box" pos="-2.025 0.6 0.5" size="0.425 0.6 0.5" quat="1 0 0 0"/>
    <!-- Box 3: 485×20×130 cm. Center in new origin: (-2.5,130,65) cm -->
    <geom name="layout_box3" type="box" pos="-0.025 1.3 0.65" size="2.425 0.1 0.65" quat="1 0 0 0"/>

  </worldbody>
</mujoco>